---
import { getCollection } from "astro:content";
import BlogListClient from "./BlogListClient.tsx";
import config from "@shConfig";

const postsPerPage = config.style.postsPerPage || 6;
// `BlogList` now delegates pagination to the client component.
const allPosts = (
  await getCollection("blog", ({ data }) => {
    // 開發環境顯示所有文章,生產環境過濾掉 draft 文章
    if (import.meta.env.DEV) return true;
    return data.draft !== true;
  })
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
// const totalPages = Math.ceil(allPosts.length / postsPerPage); // Calculate total pages based on posts per page

// Serialize posts for client-side consumption (convert dates to ISO strings)
const serializedPosts = allPosts.map((post) => {
  let heroImageSrc: string | null = null;

  if (post.data.heroImage) {
    if (typeof post.data.heroImage === 'string') {
      // 外部 URL 字符串
      heroImageSrc = post.data.heroImage;
    } else if (post.data.heroImage.src) {
      // Astro Image 对象，提取 src 属性
      heroImageSrc = typeof post.data.heroImage.src === 'string'
        ? post.data.heroImage.src
        : post.data.heroImage.src.src; // 处理嵌套的 src 对象
    }
  }

  return {
    id: post.id,
    data: {
      title: post.data.title,
      description: post.data.description,
      pubDate: post.data.pubDate.toISOString(),
      heroImage: heroImageSrc,
      category: post.data.category ?? null,
      tags: post.data.tags ?? null,
    },
  };
});
---

<BlogListClient
  client:load
  posts={serializedPosts}
  postsPerPage={postsPerPage}
/>
