---
import { Button } from "@ui/button.tsx";
import { ArrowUp } from "lucide-react";

const { class: className } = Astro.props;
---

<Button
  id="to-top-button"
  aria-label="Back to top"
  variant={"ghost"}
  className={`invisible flex items-center justify-center rounded-lg opacity-0 shadow-lg backdrop-blur-md transition-all duration-300 data-[show=true]:visible data-[show=true]:opacity-100 ${className}`}
>
  <ArrowUp className="text-white lg:rotate-90" size={20} />
  <span class="ml-4 hidden text-xs tracking-[0.3em] uppercase lg:block"
    >Back to top</span
  >
  <div class="ml-2 hidden h-px w-10 bg-gray-300/50 lg:block"></div>
</Button>

<script>
  function initToTop() {
    const scrollToTopBtn = document.getElementById(
      "to-top-button",
    ) as HTMLButtonElement;
    if (!scrollToTopBtn) return;

    const controller = new AbortController();
    const { signal } = controller;

    // 1. 显示/隐藏按钮逻辑
    const handleScroll = () => {
      const scrollTop =
        document.documentElement.scrollTop || document.body.scrollTop;
      scrollToTopBtn.setAttribute(
        "data-show",
        scrollTop > 500 ? "true" : "false",
      );
    };

    // 2. 回到顶端并重置 URL Hash
    const scrollToTop = () => {
      // 执行滚动
      window.scrollTo({
        top: 0,
        behavior: "smooth",
      });

      // 重置 URL：移除 Hash 但不重新加载页面
      // 使用 replaceState 可以避免在浏览记录中留下多余的「无 hash」记录
      if (window.location.hash) {
        const url = new URL(window.location.href);
        url.hash = "";
        history.replaceState(null, "", url.toString());
      }
    };

    // 监听事件
    window.addEventListener("scroll", handleScroll, { signal });
    scrollToTopBtn.addEventListener("click", scrollToTop, { signal });

    // 初始化状态
    handleScroll();

    // 清理机制：配合 Astro ClientRouter
    document.addEventListener(
      "astro:before-swap",
      () => {
        controller.abort();
      },
      { once: true },
    );
  }

  // 监听生命周期事件
  document.addEventListener("astro:page-load", initToTop);
</script>
