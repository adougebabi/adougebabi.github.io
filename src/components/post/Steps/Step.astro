---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="step-item flex group">
  <div class="flex flex-col items-center mr-6">
    <div
      class="step-number flex items-center justify-center w-10 h-10 rounded-full bg-[#1A1A1A] text-white text-sm font-semibold border border-white/10 shrink-0 z-10"
    >
    </div>
    <div class="w-[1px] h-full bg-white/20 group-last:hidden"></div>
  </div>

  <div class="!py-2 min-h-25">
    <span class="text-xl font-bold text-white leading-tight">
      {title}
    </span>
    <div class="text-gray-400 leading-relaxed !mt-2">
      <slot />
    </div>
  </div>
</div>

<style>
  .step-item {
    counter-increment: step-counter;
  }

  .step-number::before {
    content: counter(step-counter);
  }
</style>
