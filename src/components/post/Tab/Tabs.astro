---
import { cn } from "@lib/utils";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class={cn(
    "sh-builtin-components tabs-container my-6 rounded-lg overflow-hidden border border-white/10 bg-neutral-900",
    className,
  )}
>
  <div
    class="tabs-nav-wrapper relative border-b border-white/10 bg-neutral-900/50"
  >
    <div
      class="tab-nav scrollbar-custom relative flex overflow-x-auto overflow-y-hidden px-2 whitespace-nowrap transition-all"
    >
      <div
        class="tab-sliding-line pointer-events-none absolute bottom-0 left-0 h-[2px] bg-green-500 opacity-0 transition-all duration-300 ease-out"
        style="width: 0; transform: translateX(0);"
      >
      </div>
    </div>
  </div>

  <div class="tab-panels px-5 pt-2 pb-5">
    <slot />
  </div>
</div>

<style>
  /* 1. 自定義捲軸樣式（取代原本的隱藏邏輯） */
  .scrollbar-custom::-webkit-scrollbar {
    height: 4px; /* 較細的捲軸 */
  }
  .scrollbar-custom::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-custom::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 10px;
  }
  .scrollbar-custom::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* 2. 動態漸層邏輯 [核心修改] */
  .tabs-nav-wrapper::before,
  .tabs-nav-wrapper::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 40px;
    z-index: 20;
    pointer-events: none;
    transition: opacity 0.3s ease;
    opacity: 0;
  }

  /* 左側漸層 */
  .tabs-nav-wrapper::before {
    left: 0;
    background: linear-gradient(to right, #0f0f0f 0%, transparent 100%);
  }

  /* 右側漸層 */
  .tabs-nav-wrapper::after {
    right: 0;
    background: linear-gradient(to left, #0f0f0f 0%, transparent 100%);
  }

  /* 根據狀態顯示漸層 */
  .show-left::before {
    opacity: 1;
  }
  .show-right::after {
    opacity: 1;
  }
</style>

<script is:inline>
  (function setupEnhancedTabs() {
    const containers = document.querySelectorAll(
      ".tabs-container:not([data-initialized-enhanced])",
    );

    containers.forEach((container) => {
      container.setAttribute("data-initialized-enhanced", "true");

      const wrapper = container.querySelector(".tabs-nav-wrapper");
      const nav = container.querySelector(".tab-nav");
      const panels = container.querySelectorAll(".tab-panel");
      const line = container.querySelector(".tab-sliding-line");

      // 1. 決定預設索引：尋找 data-default-open="true" 的面板
      let defaultIndex = 0;
      panels.forEach((panel, idx) => {
        if (panel.getAttribute("data-default-open") === "true") {
          defaultIndex = idx;
        }
      });

      // --- 漸層遮罩邏輯 ---
      const updateGradients = () => {
        const scrollLeft = nav.scrollLeft;
        const maxScroll = nav.scrollWidth - nav.clientWidth;

        if (scrollLeft > 1) {
          wrapper.classList.add("show-left");
        } else {
          wrapper.classList.remove("show-left");
        }

        if (scrollLeft < maxScroll - 1) {
          wrapper.classList.add("show-right");
        } else {
          wrapper.classList.remove("show-right");
        }
      };

      nav.addEventListener("scroll", updateGradients);

      // --- 生成按鈕與初始化面板 ---
      panels.forEach((panel, idx) => {
        const label = panel.getAttribute("data-label");
        const btn = document.createElement("button");
        btn.type = "button";
        btn.innerText = label;

        // 基礎樣式 (z-10 確保在滑動線上方，flex-shrink-0 防止被擠壓)
        btn.className = `tab-button flex-shrink-0 relative z-10 px-4 py-2 text-sm font-medium transition-colors duration-300 outline-none`;

        // 根據是否為預設索引設定初始顏色
        if (idx === defaultIndex) {
          btn.classList.add("text-green-400");
          panel.classList.remove("hidden");
        } else {
          btn.classList.add("text-gray-400", "hover:text-gray-200");
          panel.classList.add("hidden");
        }

        btn.addEventListener("click", () => switchTab(btn, idx));
        nav.insertBefore(btn, line);
      });

      const updateLine = (btn, behavior = "smooth") => {
        line.style.opacity = "1";
        line.style.width = `${btn.offsetWidth}px`;
        line.style.transform = `translateX(${btn.offsetLeft}px)`;

        btn.scrollIntoView({
          behavior: behavior,
          block: "nearest",
          inline: "center",
        });
      };

      function switchTab(activeBtn, targetIdx) {
        const buttons = container.querySelectorAll(".tab-button");
        buttons.forEach((b) => {
          b.classList.remove("text-green-400");
          b.classList.add("text-gray-400", "hover:text-gray-200");
        });
        activeBtn.classList.add("text-green-400");
        activeBtn.classList.remove("text-gray-400", "hover:text-gray-200");

        updateLine(activeBtn);
        panels.forEach((p, i) => {
          if (i === targetIdx) p.classList.remove("hidden");
          else p.classList.add("hidden");
        });
      }

      // 初次渲染後計算位置
      requestAnimationFrame(() => {
        const allBtns = container.querySelectorAll(".tab-button");
        const targetBtn = allBtns[defaultIndex];
        if (targetBtn) {
          // 初始化時使用 auto 滾動避免頁面載入時產生不必要的動畫感
          updateLine(targetBtn, "auto");
        }
        updateGradients();
      });

      window.addEventListener("resize", () => {
        const activeBtn = container.querySelector(".tab-button.text-green-400");
        if (activeBtn) updateLine(activeBtn, "auto");
        updateGradients();
      });
    });
  })();
</script>
