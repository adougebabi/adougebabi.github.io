---
import { cn } from "@lib/utils";
import { Star, GitFork, SearchAlert, Circle } from "@lucide/astro";
import { Github } from "simple-icons-astro";

import I18nKey from "@i18n/i18nKey";
import i18n from "@i18n/translation";

interface Props {
  repo: `${string}/${string}`; // 格式為 "user/repo"
  class?: string;
}

const { repo, class: className } = Astro.props;

// 在建構階段抓取資料
const token = import.meta.env.GITHUB_TOKEN;

if (!token) {
  throw new Error("GitHub token is required for GitHubCard component.");
}

const response = await fetch(`https://api.github.com/repos/${repo}`, {
  headers: {
    Authorization: `Bearer ${token}`,
    "User-Agent": "Astro-Build",
  },
});

const responseData = await response.json();

let data;

if (responseData?.message === "Not Found") {
  data = null;
} else if (!response.ok) {
  throw new Error(`GitHub API error: ${response.status} for ${repo}`);
} else {
  data = responseData;
}

// 語言顏色映射（可根據需求擴充）
import { programLanguagesToColorChart as langColors } from "./colors";
import GitHubStatusBadge from "./GitHubStatusBadge.astro";

const langColor = data?.language
  ? (langColors[data.language]?.color ?? "#9198a1")
  : "#9198a1";
---

{
  data ? (
    <a
      href={data.html_url}
      target="_blank"
      rel="noopener noreferrer"
      class={cn(
        "sh-builtin-components block group px-5 py-5 rounded-lg border border-white/10 bg-neutral-900 hover:border-white/30 hover:bg-neutral-800 transition-all duration-300 no-underline mb-4",
        className,
      )}
    >
      <div class="flex items-start justify-between mb-3">
        <div class="flex items-center gap-2">
          <Github class="w-5 h-5 text-gray-400" />
          <span class="text-green-400 font-semibold text-lg group-hover:text-green-500 transition-colors duration-300">
            {data.name}
          </span>
        </div>

        <div class="ml-auto">
          <GitHubStatusBadge gitHubData={data} />
        </div>
      </div>

      <p class="text-gray-400 text-base mb-4 line-clamp-2 leading-relaxed">
        {data.description || i18n(I18nKey.github_card_no_description)}
      </p>

      <div class="flex items-center gap-4 text-xs text-gray-500">
        {data.language && (
          <div class="flex items-center gap-1.5">
            <Circle class="w-3 h-3" fill={langColor} stroke="none" />
            <span class="hover:text-blue-500 transition-colors">
              {data.language}
            </span>
          </div>
        )}

        <div class="flex items-center gap-1 hover:text-yellow-500 transition-colors">
          <Star class="w-4 h-4" />
          <span>{data.stargazers_count.toLocaleString()}</span>
        </div>

        <div class="flex items-center gap-1 hover:text-blue-500 transition-colors">
          <GitFork class="w-4 h-4" />
          <span>{data.forks_count.toLocaleString()}</span>
        </div>

        <div class="hidden sm:block ml-auto italic">
          {i18n(I18nKey.github_card_updated_at)}
          {new Date(data.updated_at).toLocaleDateString()}
        </div>
      </div>
    </a>
  ) : (
    <div
      class={cn(
        "sh-builtin-components flex flex-col items-center justify-center px-5 py-5 rounded-lg border border-white/10 bg-neutral-900 text-gray-500 text-center min-h-35",
        className,
      )}
    >
      <div class="sh-builtin-components bg-neutral-800 border size-8 flex items-center justify-center rounded-lg">
        <SearchAlert size={20} />
      </div>
      {i18n(I18nKey.github_card_not_found)}
    </div>
  )
}
