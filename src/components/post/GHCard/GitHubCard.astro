---
import { Star, GitFork, Info, Circle } from "@lucide/astro";

interface Props {
  repo: `${string}/${string}`; // 格式為 "user/repo"
  class?: string;
}

const { repo, class: className } = Astro.props;

// 在建構階段抓取資料
const token = import.meta.env.GITHUB_TOKEN;
const response = await fetch(`https://api.github.com/repos/${repo}`, {
  headers: {
    Authorization: `Bearer ${token}`,
    "User-Agent": "Astro-Build",
  },
});

if (!response.ok) {
  throw new Error(`GitHub API error: ${response.status} for ${repo}`);
}

const data = await response.json();

// 語言顏色映射（可根據需求擴充）
const langColors: Record<string, string> = {
  TypeScript: "#3178c6",
  JavaScript: "#f1e05a",
  Astro: "#ff5a03",
  CSS: "#563d7c",
  HTML: "#e34c26",
};

const langColor = langColors[data.language] || "#8b949e";
---

<a
  href={data.html_url}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    "block group p-5 rounded-xl border border-white/10 bg-[#0d1117] hover:border-blue-500/50 hover:bg-[#161b22] transition-all duration-300 no-underline",
    className,
  ]}
>
  <div class="flex items-start justify-between mb-3">
    <div class="flex items-center gap-2">
      <svg
        viewBox="0 0 16 16"
        class="w-5 h-5 fill-gray-400 group-hover:fill-blue-400 transition-colors"
      >
        <path
          d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"
        ></path>
      </svg>
      <span class="text-blue-400 font-semibold text-lg group-hover:underline">
        {data.name}
      </span>
    </div>
    <div
      class="px-2 py-0.5 rounded-full border border-white/10 text-[10px] text-gray-400 uppercase tracking-wider font-bold"
    >
      Public
    </div>
  </div>

  <p class="text-gray-400 text-sm mb-4 line-clamp-2 leading-relaxed">
    {data.description || "No description provided."}
  </p>

  <div class="flex items-center gap-4 text-xs text-gray-500">
    {
      data.language && (
        <div class="flex items-center gap-1.5">
          <Circle class="w-3 h-3" fill={langColor} stroke="none" />
          <span>{data.language}</span>
        </div>
      )
    }

    <div
      class="flex items-center gap-1 hover:text-yellow-500 transition-colors"
    >
      <Star class="w-4 h-4" />
      <span>{data.stargazers_count.toLocaleString()}</span>
    </div>

    <div class="flex items-center gap-1 hover:text-blue-500 transition-colors">
      <GitFork class="w-4 h-4" />
      <span>{data.forks_count.toLocaleString()}</span>
    </div>

    <div class="hidden sm:block ml-auto italic">
      Updated {new Date(data.updated_at).toLocaleDateString()}
    </div>
  </div>
</a>
