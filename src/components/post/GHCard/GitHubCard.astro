---
// src/components/GitHubCard.astro
import { cn } from "@lib/utils";
import { Star, GitFork, SearchAlert, Circle } from "@lucide/astro";
import I18nKey from "@i18n/i18nKey";
import i18n from "@i18n/translation";

import { fetchRepoData } from "@lib/githubCache";
import GitHubStatusBadge from "./GitHubStatusBadge.astro";

// 动态导入 GitHub 图标，避免构建时的路径解析问题
let GithubIcon: any = null;
try {
  const iconModule = await import("simple-icons-astro");
  GithubIcon = iconModule.Github;
} catch (error) {
  console.warn("Failed to load Github icon from simple-icons-astro:", error);
}

// 导入第一层：常用语言白名单 (静态导入)
import { commonLangColors } from "./commonColors";

interface Props {
  repo: `${string}/${string}` | `https://github.com/${string}/${string}`;
  class?: string;
}

const { repo, class: className } = Astro.props;
const token = import.meta.env.GITHUB_TOKEN;

if (!token) {
  throw new Error("GitHub token is required for GitHubCard component.");
}

const data = await fetchRepoData(repo);

// --- 语言颜色处理逻辑 ---
let langColor = "#9198a1"; // 预设灰色

if (data?.language) {
  // 1. 先从白名单寻找
  if (commonLangColors[data.language]) {
    langColor = commonLangColors[data.language];
  } else {
    // 2. 没命中，动态引入完整 65KB 档案
    // Vite 会将此 import 处理为异步加载，不会阻塞主束
    try {
      const fullColorsModule = await import("./colors");
      const fullColors = fullColorsModule.programLanguagesToColorChart;
      langColor = fullColors[data.language]?.color ?? "#9198a1";
    } catch (e) {
      console.error("Failed to load full color chart", e);
    }
  }
}
---

{
  data ? (
    <a
      href={data.html_url}
      target="_blank"
      rel="noopener noreferrer"
      class={cn(
        "sh-builtin-components group mb-4 block rounded-lg border border-white/10 bg-neutral-900 px-5 py-5 no-underline transition-all duration-300 hover:border-white/30 hover:bg-neutral-800",
        className,
      )}
    >
      <div class="mb-3 flex items-start justify-between">
        <div class="flex items-center gap-2">
          {GithubIcon ? (
            <GithubIcon class="h-5 w-5 text-gray-400" />
          ) : (
            <svg class="h-5 w-5 text-gray-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          )}
          <span class="text-lg font-semibold text-green-400 transition-colors duration-300 group-hover:text-green-500">
            {data.name}
          </span>
        </div>

        <div class="ml-auto">
          <GitHubStatusBadge gitHubData={data} />
        </div>
      </div>

      <p class="mb-4 line-clamp-2 text-base leading-relaxed text-gray-400">
        {data.description || i18n(I18nKey.github_card_no_description)}
      </p>

      <div class="flex items-center gap-4 text-xs text-gray-500">
        {data.language && (
          <div class="flex items-center gap-1.5">
            <Circle class="h-3 w-3" fill={langColor} stroke="none" />
            <span class="transition-colors hover:text-blue-500">
              {data.language}
            </span>
          </div>
        )}

        <div class="flex items-center gap-1 transition-colors hover:text-yellow-500">
          <Star class="h-4 w-4" />
          <span>{data.stargazers_count.toLocaleString()}</span>
        </div>

        <div class="flex items-center gap-1 transition-colors hover:text-blue-500">
          <GitFork class="h-4 w-4" />
          <span>{data.forks_count.toLocaleString()}</span>
        </div>

        <div class="ml-auto hidden italic sm:block">
          {i18n(I18nKey.github_card_updated_at)}
          {new Date(data.updated_at).toLocaleDateString()}
        </div>
      </div>
    </a>
  ) : (
    <div
      class={cn(
        "sh-builtin-components flex min-h-35 flex-col items-center justify-center gap-2 rounded-lg border border-red-50/10 bg-red-950 px-5 py-5 text-center text-red-500 transition-all duration-300 hover:border-red-50/30 hover:bg-red-900/90",
        className,
      )}
    >
      <div class="sh-builtin-components flex size-8 items-center justify-center rounded-lg border border-red-500/80 bg-red-800/50">
        <SearchAlert size={20} />
      </div>
      {i18n(I18nKey.github_card_not_found)}
    </div>
  )
}
